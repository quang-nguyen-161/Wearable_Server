# ThingsBoard Cloud credentials
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

TB_BASE_URL=https://thingsboard.cloud
TB_USERNAME=your_email@example.com
TB_PASSWORD=your_password

# Device UUID from ThingsBoard (Dashboard → Devices → click device → copy ID from URL)
TB_DEVICE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
