# ThingsBoard Cloud credentials
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

TB_BASE_URL=https://your-tb-host
TB_USERNAME=tenant@thingsboard.org
TB_PASSWORD=your_password

# Device UUID — used by the dashboard to subscribe to live telemetry via WebSocket
TB_DEVICE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Gateway device access token — used by /api/telemetry/ingest to auto-create leaf devices
# ThingsBoard → Devices → (your gateway device) → Manage credentials → Access token
TB_GATEWAY_ACCESS_TOKEN=your_gateway_access_token_here

# Public vars (embedded at build time — no secrets)
NEXT_PUBLIC_TB_WS_URL=wss://your-tb-host/api/ws/plugins/telemetry
# These two enable browser-side TB API calls (bypasses Cloudflare via login page)
NEXT_PUBLIC_TB_BASE_URL=https://your-tb-host
NEXT_PUBLIC_TB_DEVICE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Deployment
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
